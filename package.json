{
  "name": "cycloid-dt",
  "version": "1.0.0",
  "description": "Multi-themed design token pipeline with third-party mappings and Figma export.",
  "author": "Dan Danowski <dan.danowski@cycloid.io>",
  "type": "module",
  "main": "build.js",
  "scripts": {
    "sd:clean": "node -e \"fs.rmSync('build', {recursive: true, force: true})\"",
    "sd:build": "node style-dictionary/sd-tokens.build.js --verbose",
    "sd:build:mappings": "node style-dictionary/sd-tokens.build-mappings.js --verbose",
    "sd:punch-it": "npm run sd:clean && npm run sd:build && npm run sd:build:mappings"
  },
  "dependencies": {
    "@tokens-studio/sd-transforms": "^2.0.3",
    "culori": "^4.0.2",
    "style-dictionary": "^5.3.3",
    "tinycolor2": "^1.6.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}